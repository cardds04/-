node_modules/
backups/

# 분리 작업 로컬 백업 — git/배포 대상 아님 (복구는 git history로)
*.bak

# Vercel `vercel-build`가 생성(루트를 public으로 복제). 원격에서는 매 빌드마다 새로 만들어짐.
/public/

# API 키·비밀 — 커밋 금지 (.env.example 만 버전 관리)
.env
**/.env
auth_key.key
tools/crypto-balance/.trading_state.json
tools/crypto-balance/.runtime_credentials.json
tools/crypto-balance/trading.log
tools/crypto-balance/status.json
tools/crypto-balance/strategy_config.json
tools/crypto-balance/trades.json
**/.venv/
tools/grok-topaz-pipeline/web_output/
# 로컬 경로가 들어가는 리졸브 브리지 설정
tools/davinci-montage-bridge/config.json

# 대용량 모델 weights 파일 — GitHub 100MB 제한 초과
**/weights/*.pt
**/weights/*.pth
**/weights/*.ckpt
**/weights/*.bin
**/weights/*.safetensors
**/weights/models--*/
**/weights/CACHEDIR.TAG
**/__pycache__/
.vercel

# 로컬 미리보기용 심볼릭 링크(레포 루트 assets 연결) — 커밋 안 함
easy/assets

# 사장님 글씨체 — 원본(ttf/otf 117MB)은 커밋 제외, 웹용 woff2(서브셋 18MB)+선언만 배포
easy/fonts/*
!easy/fonts/myfonts.css
!easy/fonts/web/
!easy/fonts/web/*.woff2
