# 솔라피(SOLAPI) 문자 발송 — 로컬 개발 환경변수 예시
# 이 파일을 복사해서 `.env` 로 두고, 실제 값은 .env 에만 적어주세요.
# (.env 는 .gitignore 처리되어 있어 커밋되지 않습니다.)
#
# Vercel 배포 환경에서는 Vercel 프로젝트 → Settings → Environment Variables
# 에 동일한 키로 등록해주세요.

SOLAPI_API_KEY=여기에_솔라피_API_KEY
SOLAPI_API_SECRET=여기에_솔라피_API_SECRET
SOLAPI_SENDER_NUMBER=01028692443

# 단문 문자에 포함할 고객 포털 URL 기준 도메인 (예: https://your-domain.vercel.app)
# 미설정 시 배포 플랫폼 호스트명(예: VERCEL_URL)만으로도 보통 동작합니다.
# SITE_PUBLIC_ORIGIN=https://예시-production.vercel.app

# Google Drive (납품·작가 현장 확인, npm run drive:rename-company-suffix 로컬 실행 시 필요)
# GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=서비스계정_JSON_한줄또는_UTF-8_Base64
# GOOGLE_DRIVE_PARENT_FOLDER_ID=Drive URL의 /folders/ 뒤 폴더 ID
#
# 배포에서 /api/delivery-drive-cron (자동 납품·폴더 Job)을 켜려면:
# DELIVERY_DRIVE_CRON_ENABLED=1