# 솔라피(SOLAPI) 문자 발송 — 로컬 개발 환경변수 예시
# 이 파일을 복사해서 `.env` 로 두고, 실제 값은 .env 에만 적어주세요.
# (.env 는 .gitignore 처리되어 있어 커밋되지 않습니다.)
#
# Vercel 배포 환경에서는 Vercel 프로젝트 → Settings → Environment Variables
# 에 동일한 키로 등록해주세요.

SOLAPI_API_KEY=여기에_솔라피_API_KEY
SOLAPI_API_SECRET=여기에_솔라피_API_SECRET
SOLAPI_SENDER_NUMBER=01000000000

# Supabase → Project Settings → API (service_role 은 절대 공개 저장소에 넣지 마세요)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=여기에_SUPABASE_service_role_키

# Google Cloud 서비스 계정 JSON 전체를 한 줄로, 또는 Base64 인코딩 문자열
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=여기에_서비스계정_JSON_또는_Base64

# Drive에서 사용할 부모 폴더의 ID (주소창 id= 뒤 값)
GOOGLE_DRIVE_PARENT_FOLDER_ID=여기에_폴더_ID

# ---- 네이버웍스(NAVER WORKS) API 2.0 — 작가 페이지 「네이버웍스」 폴더 버튼 (Python PyJWT·requests) ----
# 개발자 콘솔 Client ID / Secret, 서비스 계정 주소(sub), RSA 개인키 PEM (줄바꿈은 \\n 으로 이스케이프)
# 클라이언트 앱에 동일 키 이름을 쓰려면 NAVER_WORKS_* 별칭도 scripts/naverworks_drive_create_folder.py 에서 지원합니다.
CLIENT_ID=여기에_CLIENT_ID
CLIENT_SECRET=여기에_CLIENT_SECRET
SERVICE_ACCOUNT=uuid@example.com
# PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
PRIVATE_KEY=
# 또는 파일 경로: NAVER_WORKS_PRIVATE_KEY_PATH=/path/to/key.pem
# NAVER_WORKS_PRIVATE_KEY_PATH=
# 토큰 scope — 공식 표는 단축 식별자(file, file.read 등). 코드는 쉼표→공백·접두 보정 후, 기본적으로 단축형만 auth.worksmobile.com 에 전송합니다.
NAVER_WORKS_OAUTH_SCOPE=file,file.read,user.profile.read
# 또는 전체 URL로 적어도 동일하게 단축으로 변환됩니다. 예전처럼 URL 그대로 보내려면: NAVER_WORKS_SCOPE_TOKEN_USE_FULL_URL=1
# NAVER_WORKS_SCOPE_TOKEN_USE_FULL_URL=
#
# 사람 계정 OAuth — 서비스 계정 JWT로 Drive 403일 때 같은 앱으로 대조 검사
# 개발자 콘솔 Redirect URL 과 아래 문자열이 완전히 같아야 함(HTTPS 필요할 수 있음).
# NAVER_WORKS_OAUTH_REDIRECT_URI=https://127.0.0.1/callback-path
# 비우면 스크립트가 기본으로 http://127.0.0.1:8877/oauth/naverworks-callback 를 쓰며 stderr에 안내함(콘솔 Redirect URL에 동일 등록).
# NAVER_WORKS_OAUTH_DOMAIN=
# SSO 테넌트는 authorize·토큰 교환 POST 모두에 domain 필요할 수 있음(네이버웍스 auth-oauth).
# 다른 인증 호스트만 쓰는 경우(예: 공공향): 공식 문서 URL 확인 후 선택적으로 지정.
# NAVER_WORKS_AUTH_TOKEN_URL=https://auth.worksmobile.com/oauth2/v2.0/token
# 검사 명령: python3 scripts/naverworks_user_oauth_drive_probe.py authorize-url
#          → python3 scripts/naverworks_user_oauth_drive_probe.py exchange-probe --code "..."
# 상위 폴더 fileId: 포토영상(공용) 안에서 **모든 업체 폴더의 직속 부모** (= Google 의 GOOGLE_DRIVE_PARENT_FOLDER_ID 역할)
# 전체 업체 일괄 생성(맥 미니·루트 `.env` 후): npm run delivery:provision-company-all-naver → company_directory.naver_works_* 저장
# 작가 「네이버웍스」버튼은 DB에 업체 폴더가 있으면 그 아래에 촬영일 폴더를 만들고, 없으면 이 값을 부모로 사용
NAVER_WORKS_DRIVE_PARENT_FILE_ID=
# 공용(협업) 드라이브 예: 포토영상 — 설정 시 POST …/sharedrives/{ID}/files 로 생성(서비스 계정을 해당 공용 폴더 구성원으로 등록 필요). 비우면 내 드라이브 users/…
# NAVER_WORKS_DRIVE_SHAREDRIVE_ID=@2101000000000008
# 또는: NAVER_WORKS_PARENT_FILE_ID=
# 서비스 계정 JWT 기본(users/me)=서비스 계정 드라이브. 부모 폴더가 **작가 등 다른 사람** 내 드라이브면 필수↓
# NAVER_WORKS_DRIVE_OWNER_USER_ID=그구성원@웍스도메인 또는 Directory API 에서 받은 userId(리소스 ID)
# Works API REST 베이스(드라이브·링크 공통). 공식 문서: https://www.worksapis.com/v1.0/…
# NAVER_WORKS_WORKSAPIS_BASE=https://www.worksapis.com/v1.0
# 폴더 생성: POST …/users/{me|OWNER}/drive/files/{부모_fileId}. …/users/me 은 액세스 토큰 주체 보통 서비스 계정
# NAVER_WORKS_DRIVE_FOLDER_CREATE_FILE_SIZE=0
# NAVER_WORKS_DRIVE_FOLDER_MODIFIED_TIME=   (선택, ISO-8601)
# users/me 403(서비스 계정) 시: 메일로 경로 고정 → users/{SERVICE_ACCOUNT}/drive/…
# NAVER_WORKS_DRIVE_FOLDER_USER_PATH=service_account
# NAVER_WORKS_SERVICE_ACCOUNT_ID=   (비우면 SERVICE_ACCOUNT / NAVER_WORKS_SERVICE_ACCOUNT 사용)
# 진단: create_folder.py --list-folder-children → 루트는 GET …/drive/files(공식). /root/children 아님.
# NAVER_WORKS_DRIVE_CREATE_FOLDER_URL=
# NAVER_WORKS_FOLDER_CREATE_JSON_EXTRA=
# 실행 Python (Fly Docker 등 기본: /opt/venv/bin/python 로 자동 시도 후 python3 폴백)
# NAVER_WORKS_PYTHON_BIN=/opt/venv/bin/python

# 공유 링크(create_folder.py / POST .../link) — 편집 가능 = linkPermissionType EDIT 권장
# NAVER_WORKS_LINK_ACCESS_TYPE=ORGANIZATION
# NAVER_WORKS_LINK_PERMISSION_TYPE=EDIT
# NAVER_WORKS_LINK_EXPIRATION=
# NAVER_WORKS_LINK_SPECIFIC_PEOPLE=작가@example.com,작가2@example.com
# NAVER_WORKS_LINK_PASSWORD=

# Google Drive — 새 폴더 생성을 끄고 싶을 때만 아래처럼 0 (미설정·비우면 기본 허용, 별도로 1 일 필요 없음)
# DELIVERY_DRIVE_ALLOW_NEW_FOLDERS=0
# DELIVERY_DRIVE_CRON_ENABLED=1
