# =============================================================================
# 환경 변수 예시 — 이 파일만 저장소에 올라갑니다.
# 실제 키는 복사해서 .env 를 만들고 채우세요:  cp .env.example .env
# .env 는 .gitignore 로 커밋되지 않습니다. 절대 키를 예시 파일에 넣지 마세요.
#
# 나중에 입력: UPBIT_* / GEMINI_* 를 비워 두고 python dashboard.py 로 웹을 연 뒤
# 「API 키 저장」폼에서 넣으면 .runtime_credentials.json 에 저장됩니다(역시 git 제외).
# main.py 는 키가 없으면 종료하지 않고 약 60초마다 다시 시도합니다.
# =============================================================================

# --- 업비트 Open API (필수: exchange_helper.py, main.py, fetch_balance.py) ---
UPBIT_API_KEY=
UPBIT_SECRET=
# HTTP 타임아웃(ms). 타임아웃이 잦으면 늘리기 (기본 30000)
# UPBIT_TIMEOUT_MS=30000

# --- (선택) fetch_balance.py 만 빗썸 쓸 때 ---
EXCHANGE=upbit
BITHUMB_API_KEY=
BITHUMB_SECRET=

# --- 자동매매 main.py ---
TRADING_SYMBOL=BTC/KRW
# 시장가 매수 시 사용할 원화 금액(거래소 최소 주문 금액 이상)
BUY_KRW_AMOUNT=6000
# 가격 확인 주기(초)
LOOP_SECONDS=60
# 익절·손절을 메인 루프와 별도로 재확인(TP_SL_RECHECK_SEC 초). 0이면 끔.
# TP_SL_RECHECK_SEC=30
# 손절 재확인: 미설정 시 내부 기본 8초와 TP_SL 중 짧은 간격. TP만의 간격 쓰려면 STOP_LOSS_RECHECK_SEC=0
# STOP_LOSS_RECHECK_SEC=8
# 시장가 매도(익절·손절 등) 직후 해당 종목을 감시 목록에서 제외할 시간(초, 기본 300)
# WATCH_EXCLUDE_AFTER_SELL_SEC=300
# 매도 직후 동일 종목 자동 재매수 금지(초, 기본 300). 0이면 끔. 상태는 sold_rebuy_cooldown_until(매도 시각 epoch)
# REBUY_AFTER_SELL_SEC=300
# 업무시작(trading_enabled) OFF여도 손절 %가 있으면 자동 매도(기본). 완전 끄려면:
# STOP_LOSS_WHEN_TRADING_DISABLED=0
# 봇 재시작 후 코인만 보유 중일 때, 매도 판단용 매수 평단(해당 심볼의 원화 가격, 선택)
# ENTRY_PRICE_FALLBACK=

LOG_LEVEL=INFO
# 로그 파일 경로(기본: tools/crypto-balance/trading.log)
# TRADING_LOG_FILE=trading.log

# 웹 대시보드 (python dashboard.py 또는 uvicorn dashboard:app)
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8765
# 코드 수정 시 자동 재시작: ./dev_dashboard.sh 사용 또는 DASHBOARD_RELOAD=1 python3 dashboard.py
# DASHBOARD_RELOAD=1

# --- (선택) 채팅 AI — Google Gemini (AI Studio API 키). 설정 시 대화·전략 수정이 LLM으로 동작합니다.
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GOOGLE_API_KEY=   # GEMINI_API_KEY 와 동일 용도로 사용 가능
# GEMINI_MODEL=gemini-2.0-flash
# CHAT_DISABLE_LLM=1   # 1 이면 키가 있어도 규칙 기반만 사용
# CHAT_DISABLE_OPENAI=1  # 위와 동일(예전 이름 호환)
